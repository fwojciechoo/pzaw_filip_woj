<form action="/new_hotel" method="POST">
  <div>
    <label for="hotel_name">Nazwa hotelu</label>
    <input
      type="text"
      name="name"
      id="hotel_name"
      required
      minlength="3"
      maxlength="100"
      <% if (locals.name){ %>
      value="<%= name %>"
      <% }%>
    />
  </div>
  <div>
    <button>Dodaj</button>
  </div>
</form>
