<%- include("head.partial.ejs") %>
<main>
  <h1><%= title %></h1>
  <% if (user && user.is_admin) { %>
    <a href="/edit/<%= hotel.slug %>" class="action-link">Zarządzaj opiniami</a>
  <% } %>
  <% if (hotel.reviews && hotel.reviews.length > 0) { %>
    <ul id="hotelreviews">
      <% hotel.reviews.forEach(function(review){ %>
      <li>
        Anonimowy użytkownik <%= review.front %> - <%= review.back %>
      </li>
      <% }) %>
    </ul>
  <% } else { %>
    <p>Nie ma żadnych opinii dla hotelu.</p>
  <% } %>
  <% if (user) { %>
  <div>
    <h3>Napisz opinie</h3>
    <%- include("forms/new_review.ejs") %>
  </div>
  <% } %>
</main>

<%- include("foot.partial.ejs") %>
