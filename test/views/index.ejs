<!DOCTYPE html>
<html>
<head>
  <title>Guestbook</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
<header>
  <h1>Hotel Guestbook</h1>
</header>
<main>
  <nav>
    <span>Welcome, <%= user.login %> (<%= user.role %>)</span> |
    <a href="/add-entry">Add Entry</a> |
    <a href="/logout">Logout</a>
  </nav>

  <% if (entries && entries.length > 0) { %>
    <ul class="entries">
      <% entries.forEach(function(entry) { %>
        <li>
          <div class="entry-header">
            <span class="entry-title"><%= entry.title %></span>
            <span class="entry-author">by <%= entry.user_login %> | Rating: <%= entry.rating %></span>
          </div>
          <div class="entry-content"><%= entry.content %></div>
          <% if (user.role === 'admin' || user.id === entry.user_id) { %>
            <form method="POST" action="/delete-entry/<%= entry.id %>" style="margin-top:8px;">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
              <button type="submit">Delete</button>
            </form>
          <% } %>
        </li>
      <% }) %>
    </ul>
  <% } else { %>
    <p>No entries yet.</p>
  <% } %>
</main>
</body>
</html>